MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/screencast-app?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

MAX_FILE_SIZE=50MB
# Local development default
UPLOAD_PATH=./uploads
# For Vercel/serverless, set this to /tmp/uploads in Vercel env vars
# UPLOAD_PATH=/tmp/uploads