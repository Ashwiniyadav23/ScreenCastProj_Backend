# Backend Environment Configuration

# Port
PORT=5001

# MongoDB Connection (replace with your MongoDB Atlas URI)
# For production: mongodb+srv://username:password@cluster.mongodb.net/screencast-app
MONGODB_URI=mongodb://localhost:27017/screencast-app

# JWT Secret Key (MUST be changed for production - generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Token Expiration
JWT_EXPIRES_IN=7d

# Frontend URL for CORS (use the same variable name as in server.js)
FRONTEND_URL=http://localhost:5173

# Upload directory for recordings
UPLOAD_DIR=uploads

# Environment
NODE_ENV=development